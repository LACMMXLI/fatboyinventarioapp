# ===========================
# InventarioApp Fatboy
# ===========================

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=inventarioapp

# JWT
JWT_SECRET=your-super-secret-key-change-this
JWT_EXPIRES_IN=24h

# API
API_PORT=3000
API_PREFIX=api
CORS_ORIGIN=http://localhost:5173

# Frontend
# In production, include /api or leave only the backend origin; the frontend normalizes an origin-only URL to /api.
# Backend CORS origins must not include a trailing slash.
VITE_API_URL=http://localhost:3000/api
